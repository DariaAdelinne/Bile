<!DOCTYPE web-app PUBLIC
        "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
        "http://java.sun.com/dtd/web-app_2_3.dtd" >
<web-app>
    <display-name>Web Component App</display-name>

    <!-- Listenerul porneste threadul de monitorizare cand aplicatia porneste -->
    <listener>
        <listener-class>servlet.AppContextListener</listener-class>
    </listener>

    <!-- Servlet pentru adaugare student -->
    <servlet>
        <servlet-name>ProcessStudent</servlet-name>
        <servlet-class>servlet.ProcessStudentServlet</servlet-class>
    </servlet>

    <!-- Servlet pentru afisare lista studenti -->
    <servlet>
        <servlet-name>FetchStudentList</servlet-name>
        <servlet-class>servlet.FetchStudentListServlet</servlet-class>
    </servlet>

    <!-- Servlet pentru update student -->
    <servlet>
        <servlet-name>UpdateStudent</servlet-name>
        <servlet-class>servlet.UpdateStudentServlet</servlet-class>
    </servlet>

    <!-- Servlet pentru delete student -->
    <servlet>
        <servlet-name>DeleteStudent</servlet-name>
        <servlet-class>servlet.DeleteStudentServlet</servlet-class>
    </servlet>

    <!-- Servlet pentru pagina de alarmare -->
    <servlet>
        <servlet-name>AlarmServlet</servlet-name>
        <servlet-class>servlet.AlarmServlet</servlet-class>
    </servlet>

    <!-- Maparea URL-urilor catre servleturi -->
    <servlet-mapping>
        <servlet-name>ProcessStudent</servlet-name>
        <url-pattern>/process-student</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>FetchStudentList</servlet-name>
        <url-pattern>/fetch-student-list</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>UpdateStudent</servlet-name>
        <url-pattern>/update-student</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DeleteStudent</servlet-name>
        <url-pattern>/delete-student</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AlarmServlet</servlet-name>
        <url-pattern>/alarm</url-pattern>
    </servlet-mapping>
</web-app>