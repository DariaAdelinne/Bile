digraph G {
  rankdir=TB; graph [fontname="Arial"]; node [shape=record, fontname="Arial"];
  Event [label="{StatisticsEvent|auctionId: String\ntype: StatisticsEventType\ntimestampEpochMillis: Long|serialize()\ndeserialize()}"];
  Client [label="{StatisticsClient|host: String\nport: Int\nauctionId: String|record(type)}"];
  Processor [label="{StatisticsStreamProcessorMicroservice|port: Int\nservice: AuctionStatisticsService|run()}"];
  Service [label="{AuctionStatisticsService|states: Map|accept(event)\nfinish(event)}"];
  Repo [label="{AuctionStatisticsRepository interface|save(summary)}"];
  CsvRepo [label="{CsvAuctionStatisticsRepository|path: Path|save(summary)}"];
  Summary [label="{AuctionStatisticsSummary|auctionId\nstartedAt\nadjudicatedAt\ntotalMessages\ncounts}"];
  Client -> Event;
  Processor -> Service;
  Service -> Repo;
  CsvRepo -> Repo [arrowhead=empty];
  Service -> Summary;
  CsvRepo -> Summary;
}
