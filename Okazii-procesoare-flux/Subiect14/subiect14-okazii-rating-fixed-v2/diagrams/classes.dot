digraph G {
 rankdir=LR; graph [fontname="DejaVu Sans"]; node [shape=record,fontname="DejaVu Sans"];
 Message [label="{Message|sender: String\lbody: String\ltimestampEpochMillis: Long\l|serialize()\ldeserialize()\luniqueKey()\l}"];
 Auctioneer [label="{AuctioneerMicroservice|bidderConnections\lbids\l|run()\lforwardBids()\lnotifyBidders()\l}"];
 MP [label="{MessageProcessorMicroservice||run()\lprocessConnection()\lforward()\l}"];
 BP [label="{BiddingProcessorMicroservice||run()\ldecide()\lsendWinner()\l}"];
 Bidder [label="{BidderMicroservice|username\lrequestedRating\l|run()\lreadRatingFromConsole()\l}"];
 RC [label="{RatingClient||submit(username, score)\l}"];
 Rating [label="{Rating|username: String\lscore: Int\ltimestampEpochMillis: Long\l}"];
 Repo [label="{«interface» RatingRepository||save(rating)\l}"];
 Csv [label="{CsvRatingRepository|path: Path\l|save(rating)\l}"];
 Validator [label="{RatingValidator||validate(username, score)\l}"];
 App [label="{RatingApplicationService|repository\lvalidator\l|submit(message)\l}"];
 RMS [label="{RatingMicroservice|port\lapp\l|run()\lhandle(socket)\l}"];
 Auctioneer -> Message; MP -> Message; BP -> Message; Bidder -> Message; RC -> Message;
 Bidder -> RC [label="uses"];
 Csv -> Repo [arrowhead=empty,label="implements"];
 App -> Repo [label="depends on abstraction"];
 App -> Validator;
 RMS -> App;
 Repo -> Rating;
}
