digraph G {
  rankdir=LR; graph [fontname="DejaVu Sans"]; node [shape=box, style="rounded", fontname="DejaVu Sans"];
  Bidder [label="BidderMicroservice\nClient / Presentation"];
  Auctioneer [label="AuctioneerMicroservice\nOrchestration / Application"];
  MessageProcessor [label="MessageProcessorMicroservice\nProcessing / Application"];
  BiddingProcessor [label="BiddingProcessorMicroservice\nDomain decision"];
  Rating [label="RatingMicroservice\nApplication + Persistence"];
  CSV [shape=cylinder,label="data/ratings.csv\nInfrastructure"];
  Bidder -> Auctioneer [label="TCP 1500: ofertă"];
  Auctioneer -> MessageProcessor [label="TCP 1600: flux oferte"];
  MessageProcessor -> BiddingProcessor [label="TCP 1700: oferte curate"];
  BiddingProcessor -> Auctioneer [label="TCP 1501: câștigător"];
  Auctioneer -> Bidder [label="rezultat"];
  Bidder -> Rating [label="TCP 1800: nume + 1..5"];
  Rating -> CSV [label="append CSV"];
}
