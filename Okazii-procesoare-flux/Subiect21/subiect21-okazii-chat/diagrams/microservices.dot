digraph G {
  rankdir=LR;
  graph [fontname="DejaVu Sans", bgcolor="white", pad="0.3"];
  node [shape=box, style="rounded", fontname="DejaVu Sans"];
  edge [fontname="DejaVu Sans"];

  subgraph cluster_auction {
    label="Flux licitație (Laboratorul 7)";
    Bidder [label="BidderMicroservice\n(replicat per ofertant)"];
    Auctioneer [label="AuctioneerMicroservice"];
    MsgProc [label="MessageProcessorMicroservice\nflux reactiv: distinct + sort"];
    BidProc [label="BiddingProcessorMicroservice"];
    Bidder -> Auctioneer [label="ofertă TCP :1500"];
    Auctioneer -> MsgProc [label="oferte :1600"];
    MsgProc -> BidProc [label="oferte procesate :1700"];
    BidProc -> Auctioneer [label="câștigător :1501"];
    Auctioneer -> Bidder [label="rezultat"];
  }

  subgraph cluster_chat {
    label="Discuție privată";
    U1 [label="UserCommunication\nDaria :1901"];
    U2 [label="UserCommunication\nMihai :1902"];
    U3 [label="UserCommunication\nIoana :1903"];
    Stream [label="ChatStreamProcessor\n:1810\nfiltrare duplicate + validare"];
    Master [label="ChatMasterMicroservice\n:1800\nregistru + camere + autorizare"];
    U1 -> Master [label="REGISTER / CREATE"];
    U2 -> Master [label="REGISTER"];
    U3 -> Master [label="REGISTER"];
    U1 -> Stream [label="CHAT"];
    U2 -> Stream [label="CHAT"];
    U3 -> Stream [label="CHAT"];
    Stream -> Master [label="DELIVER"];
    Master -> U1 [label="PRIVATE"];
    Master -> U2 [label="PRIVATE"];
    Master -> U3 [label="PRIVATE"];
  }
}
