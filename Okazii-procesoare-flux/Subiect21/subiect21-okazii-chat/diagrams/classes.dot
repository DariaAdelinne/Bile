digraph Classes {
  rankdir=LR;
  graph [fontname="DejaVu Sans", bgcolor="white", pad="0.3"];
  node [shape=record, fontname="DejaVu Sans"];

  ChatMessage [label="{ChatMessage|id; roomId; sender; text; timestamp|serializeToText(); deserialize()}"];
  UserEndpoint [label="{UserEndpoint|username; host; port}"];
  PrivateRoom [label="{PrivateRoom|id; members}"];
  UserRegistry [label="{«interface» UserRegistry|register(); find()}"];
  InMemoryUserRegistry [label="{InMemoryUserRegistry|users|register(); find()}"];
  RoomRepository [label="{«interface» RoomRepository|save(); find()}"];
  InMemoryRoomRepository [label="{InMemoryRoomRepository|rooms|save(); find()}"];
  Conversation [label="{PrivateConversationService|users; rooms|register(); createRoom(); deliver()}"];
  Master [label="{ChatMasterMicroservice|port; service|run(); handle(); process()}"];
  Gateway [label="{«interface» ChatGateway|deliver()}"];
  TcpGateway [label="{TcpChatGateway|masterHost; masterPort|deliver()}"];
  Stream [label="{ChatStreamProcessorMicroservice|port; gateway; processedIds|run(); socketStream(); process()}"];
  MasterClient [label="{«interface» MasterClient|register(); createRoom()}"];
  StreamClient [label="{«interface» StreamChatClient|send()}"];
  UserComm [label="{UserCommunicationMicroservice|username; listenPort; roomId|run(); receive()}"];

  InMemoryUserRegistry -> UserRegistry [arrowhead=empty, style=dashed];
  InMemoryRoomRepository -> RoomRepository [arrowhead=empty, style=dashed];
  Conversation -> UserRegistry;
  Conversation -> RoomRepository;
  Conversation -> PrivateRoom;
  Conversation -> UserEndpoint;
  Master -> Conversation;
  TcpGateway -> Gateway [arrowhead=empty, style=dashed];
  Stream -> Gateway;
  Stream -> ChatMessage;
  UserComm -> MasterClient;
  UserComm -> StreamClient;
  UserComm -> ChatMessage;
}
